{
  "trial_id": "phase1-codex-gpt-run14",
  "phase": "phase1-toolchain-native-baseline",
  "allowed_variable": "toolchain",
  "baseline_ref": "HEAD",
  "repo_root": ".",
  "workspace_root": "experiments/trials",
  "artifact_root": "experiments/artifacts",
  "cache_policy": "cold",
  "tool": {
    "name": "codex",
    "version": "record-with-codex-version-command",
    "command": "zsh",
    "args": [
      "-lc",
      "codex exec --disable tui_app_server --dangerously-bypass-approvals-and-sandbox -c 'model_provider=\"amazon-bedrock\"' -c 'shell_environment_policy.inherit=\"all\"' --model openai.gpt-5.5 < PROMPT.md"
    ],
    "env": {}
  },
  "models": {
    "planning": "openai.gpt-5.5",
    "code": "openai.gpt-5.5",
    "test": "openai.gpt-5.5",
    "judge": "openai.gpt-5.5"
  },
  "sampling": {
    "temperature": 0,
    "top_p": 1,
    "max_tokens": 8192
  },
  "loop": {
    "strategy": "test-driven",
    "max_iterations": 60
  },
  "context": {
    "strategy": "artifact-only"
  },
  "capabilities": {
    "profile": "standard-autonomous",
    "browser": true,
    "subagents": true,
    "package_install": true,
    "skills": "existing-only",
    "mcp": "existing-only"
  },
  "verification": {
    "commands": [
      ["pnpm", "typecheck"],
      ["pnpm", "lint"],
      ["pnpm", "test"],
      ["pnpm", "build"]
    ]
  }
}
